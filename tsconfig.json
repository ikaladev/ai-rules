{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "lib": [
            "ES2020"
        ],
        "outDir": "out",
        "sourceMap": true,
        "strict": true,
        "rootDir": ".",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true
    },
    "include": [
        "src/**/*",
        "packages/**/*",
        "scripts/**/*"
    ],
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}
